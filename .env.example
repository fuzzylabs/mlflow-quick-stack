# ============================================================================
# MLflow Quick Stack — Environment Configuration
# ============================================================================
# Copy this file to .env and customise before running `docker compose up -d`
#
#   cp .env.example .env
#
# ── Generating Secrets / Passwords / Keys ────────────────────────────────────
# Random URL-safe token (for secret keys & passphrases):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   openssl rand -base64 32
#
# Random alphanumeric password (min 13 chars for MLflow):
#   openssl rand -base64 16 | tr -dc 'A-Za-z0-9!@#' | head -c 16
#   python -c "import secrets, string; print(''.join(secrets.choice(string.ascii_letters + string.digits + '-!@#') for _ in range(16)))"
#
# Bcrypt hash for Traefik basicAuth:
#   htpasswd -nbB admin 'your-password'
#   docker run --rm httpd:2 htpasswd -nbB admin 'your-password'
# ============================================================================

# ── Domain Configuration ─────────────────────────────────────────────────────
# Base domain used for Traefik routing.  Subdomains are derived automatically
# inside the dynamic Traefik config (traefik/dynamic/config.yml).
# Defaults work with /etc/hosts entries pointing *.local.dev → 127.0.0.1
DOMAIN=local.dev
MLFLOW_DOMAIN=mlflow.local.dev
MINIO_DOMAIN=minio.local.dev
S3_DOMAIN=s3.local.dev
TRAEFIK_DOMAIN=traefik.local.dev

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Generate password:  openssl rand -base64 16
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow-s3cr3t!
POSTGRES_DB=mlflow

# ── MinIO (S3-compatible object store) ───────────────────────────────────────
# Generate password:  openssl rand -base64 16
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio-s3cr3t!

# ── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_VERSION=v3.10.0
MLFLOW_PORT=5000

# MLflow built-in auth admin credentials.
# Password MUST be ≥ 13 characters (MLflow v3.10+ requirement).
# Also stored in volumes/mlflow/basic_auth.ini — keep both in sync.
# Generate password:  openssl rand -base64 16
MLFLOW_AUTH_ADMIN_USERNAME=admin
MLFLOW_AUTH_ADMIN_PASSWORD=admin-s3cr3t!

# Signs session cookies. Change before any real use.
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(32))"
MLFLOW_FLASK_SERVER_SECRET_KEY=change-me-to-a-random-secret-key

# Passphrase for encrypting AI Gateway secrets at rest (KEK).
# If changed after secrets exist, rotate with:  docker compose exec mlflow mlflow crypto rotate-kek
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(32))"
MLFLOW_CRYPTO_KEK_PASSPHRASE=change-me-to-a-random-passphrase

# ── S3 Buckets ──────────────────────────────────────────────────────────────
S3_BUCKET_MLFLOW=mlflow
S3_BUCKET_QUANTIZED_MODELS=quantized-models
S3_BUCKET_FULL_PRECISION_MODELS=full-precision-models
S3_BUCKET_DATASETS=datasets

# Artifact / S3 connection (used by both the server and client SDKs)
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY must match MINIO_ROOT_USER/PASSWORD
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minio-s3cr3t!
AWS_DEFAULT_REGION=us-east-1

# ── Ollama (local LLM inference) ───────────────────────────────────────────
# Ollama runs on the host machine — Docker containers reach it via
# host.docker.internal.  No API key needed.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Traefik Dashboard Basic-Auth ─────────────────────────────────────────────
# Only protects the Traefik dashboard. MLflow and MinIO handle their own auth.
# The hash is stored in volumes/traefik/dynamic/config.yml — Traefik's file
# provider does NOT interpolate env vars, so this is for REFERENCE ONLY.
# To change the password:
#   1. Generate a hash:  htpasswd -nbB admin 'your-password'
#      (or: docker run --rm httpd:2 htpasswd -nbB admin 'your-password')
#   2. Paste the full user:hash line into volumes/traefik/dynamic/config.yml
#   3. Double-escape $ signs → $$ when storing here
# Default = admin / admin  (change in production!)
TRAEFIK_BASIC_AUTH=admin:$$2y$$05$$gTbJjAiwxIIHZgrqfHoHCeR7u/w1FwowVo5vLhtJ0BjtOhtDytpx2

# ── Localhost Direct Access (bypass Traefik) ─────────────────────────────────
# Set to a port number to expose services directly on localhost.
# These ports are used by an external reverse proxy (e.g. Caddy) or for
# direct browser access during development.
# Comment out or leave empty to only access via Traefik HTTPS subdomains.
LOCALHOST_MLFLOW_PORT=5000
LOCALHOST_MINIO_CONSOLE_PORT=9001
LOCALHOST_MINIO_API_PORT=9000
